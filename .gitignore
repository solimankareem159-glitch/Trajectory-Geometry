# =============================================================================
# Trajectory Geometry - .gitignore
# =============================================================================

# --- Python ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
*.egg

# --- Virtual Environments ---
.venv*/
venv/
exp19_venv/

# --- Jupyter ---
.ipynb_checkpoints/

# --- Model Cache & Large Binaries ---
.cache/
*.bin
*.safetensors
*.gguf
*.pt
*.pth
*.onnx

# --- Experimental Data Files (too large for git) ---
# Hidden state arrays (often 100MB+ each)
*.npy
*.npz

# Large dataset files
*.pkl
*.pickle
*.h5
*.hdf5

# --- Node.js (Visualisation Tool) ---
visualisation_tool/node_modules/
visualisation_tool/dist/
visualisation_tool/data/

# --- IDE / Editor ---
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Claude / Agent Config ---
.agent/
.claude/

# --- Sensitive / Private ---
.env
*.log

# --- Archive (Internal Working Materials) ---
experiments/.Archive/
.Archive/
archive/research_design/*.pdf
archive/research_journey/
